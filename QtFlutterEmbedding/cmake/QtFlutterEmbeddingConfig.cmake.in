# QtFlutterEmbeddingConfig.cmake — generated by configure_package_config_file.
# Do not edit; edit QtFlutterEmbeddingConfig.cmake.in instead.
@PACKAGE_INIT@

# Path to the Flutter Windows engine artifacts baked in at build time.
# Consuming projects that installed the library from a different machine should
# override this by setting FLUTTER_ENGINE_DIR before calling find_package.
set(QTFLUTTEREMBEDDING_FLUTTER_ENGINE_DIR "@FLUTTER_ENGINE_DIR@")
if(DEFINED FLUTTER_ENGINE_DIR)
    set(QTFLUTTEREMBEDDING_FLUTTER_ENGINE_DIR "${FLUTTER_ENGINE_DIR}")
endif()

# Re-create the flutter_windows imported target so consumers get the engine
# headers and the import library without needing to know FLUTTER_ENGINE_DIR.
if(NOT TARGET flutter_windows)
    if(NOT EXISTS "${QTFLUTTEREMBEDDING_FLUTTER_ENGINE_DIR}/flutter_windows.dll")
        message(FATAL_ERROR
            "QtFlutterEmbedding: flutter_windows.dll not found at "
            "'${QTFLUTTEREMBEDDING_FLUTTER_ENGINE_DIR}'. "
            "Set FLUTTER_ENGINE_DIR to the Flutter Windows engine artifacts "
            "directory before calling find_package(QtFlutterEmbedding).")
    endif()
    add_library(flutter_windows SHARED IMPORTED)
    set_target_properties(flutter_windows PROPERTIES
        IMPORTED_LOCATION
            "${QTFLUTTEREMBEDDING_FLUTTER_ENGINE_DIR}/flutter_windows.dll"
        IMPORTED_IMPLIB
            "${QTFLUTTEREMBEDDING_FLUTTER_ENGINE_DIR}/flutter_windows.dll.lib"
        INTERFACE_INCLUDE_DIRECTORIES
            "${QTFLUTTEREMBEDDING_FLUTTER_ENGINE_DIR}"
    )
endif()

include(CMakeFindDependencyMacro)
find_dependency(Qt6 REQUIRED COMPONENTS Core Quick Widgets)

include("${CMAKE_CURRENT_LIST_DIR}/QtFlutterEmbeddingTargets.cmake")

check_required_components(QtFlutterEmbedding)
